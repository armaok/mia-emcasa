    {
      "parameters": {
        "jsCode": "const phone = $('Extrai texto1').first().json.phone;\nconst message = $('Extrai texto1').first().json.message;\nconst messageId = $('Extrai texto1').first().json.messageId || '';\nif (!message || message.trim() === '') { return []; }\nlet historico = [];\nlet lastMessage = '';\nlet lastMessageAt = null;\nlet lastMessageId = '';\ntry {\n  const rows = $('Busca histórico1').all();\n  if (rows.length > 0 && rows[0].json.historico) {\n    historico = JSON.parse(rows[0].json.historico);\n    lastMessage = rows[0].json.last_message || '';\n    lastMessageAt = rows[0].json.last_message_at ? new Date(rows[0].json.last_message_at) : null;\n    lastMessageId = rows[0].json.last_message_id || '';\n  }\n} catch(e) { historico = []; }\nif (messageId && messageId === lastMessageId) { return []; }\nconst agora = new Date();\nconst diff = lastMessageAt ? (agora - lastMessageAt) / 1000 : 999;\nif (message === lastMessage && diff < 30) { return []; }\nhistorico = historico.filter(m => m.content && m.content.trim() !== '');\nhistorico.push({ role: 'user', content: message });\nreturn [{ json: { phone, message, messageId, historico } }];"
      },
