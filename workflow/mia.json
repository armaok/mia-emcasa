    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst messageType = Object.keys(body.data.message || {})[0];\nif (!messageType || messageType === 'protocolMessage' || messageType === 'reactionMessage') { return []; }\nconst remoteJid = body.data.key.remoteJid || '';\nconst phone = remoteJid.replace('@s.whatsapp.net', '').replace('@lid', '');\nconst message = body.data.message?.conversation || body.data.message?.extendedTextMessage?.text || '';\nconst instance = body.instance || 'teste';\nconst messageId = body.data.key.id || '';\nreturn [{ json: { phone, message, instance, messageId } }];"
      },
